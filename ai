local function GetTarget()
    local t, dist = nil, Combat.FOV
    local cen = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(Combat.TargetPart) and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local pos, vis = Camera:WorldToViewportPoint(p.Character[Combat.TargetPart].Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - cen).Magnitude
                if mag < dist then dist = mag t = p.Character[Combat.TargetPart] end
            end
        end
    end
    return t
end

RunService.RenderStepped:Connect(function()
    if Combat.Enabled and HoldingRMB then
        GLOBALS.Target = GetTarget()
        if GLOBALS.Target then
            local pos = Camera:WorldToViewportPoint(GLOBALS.Target.Position)
            local cen = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            local delta = Vector2.new(pos.X, pos.Y) - cen
            if mousemoverel then
                mousemoverel(delta.X / Combat.Smoothing, delta.Y / Combat.Smoothing)
            else
                local cCF = Camera.CFrame
                Camera.CFrame = cCF:Lerp(CFrame.new(cCF.Position, GLOBALS.Target.Position), 1 / (Combat.Smoothing * 2))
            end
        end
    end
end)

