                BackgroundColor3 = state and Color3.new(1,1,1) or Theme.TextSub
            }):Play()
            callback(state)
        end)
    end

    function TabAPI:CreateSlider(title, min, max, default, isFloat, callback)
        local c = Make("Frame", {Size = UDim2.new(1, 0, 0, 75), BackgroundColor3 = Theme.ItemBG}, page)
        Round(c, 8) Stroke(c, Theme.Border)
        Make("TextLabel", {Size = UDim2.new(1, -70, 0, 20), Position = UDim2.new(0, 20, 0, 12), BackgroundTransparency = 1, Text = title, TextColor3 = Theme.TextMain, Font = Fonts.Body, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left}, c)
        
        local vLbl = Make("TextLabel", {Size = UDim2.new(0, 50, 0, 20), Position = UDim2.new(1, -70, 0, 12), BackgroundTransparency = 1, Text = tostring(default), TextColor3 = Theme.Primary, Font = Fonts.Code, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Right}, c)
        
        local track = Make("Frame", {Size = UDim2.new(1, -40, 0, 8), Position = UDim2.new(0, 20, 0, 48), BackgroundColor3 = Theme.AppBG}, c)
        Round(track, 4) Stroke(track, Theme.Border)
        
        local pct = (default - min) / (max - min)
        local fill = Make("Frame", {Size = UDim2.new(pct, 0, 1, 0), BackgroundColor3 = Theme.Primary}, track)
        Round(fill, 4)
        local knob = Make("Frame", {Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -8, 0.5, -8), BackgroundColor3 = Color3.new(1,1,1)}, fill)
        Round(knob, 8)
        
        local tBtn = Make("TextButton", {Size = UDim2.new(1, 0, 1, 20), Position = UDim2.new(0, 0, 0, -10), BackgroundTransparency = 1, Text = ""}, track)
        
        local drag = false
        local function update(i)
            local p = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local val = min + (max - min) * p
            if not isFloat then val = math.floor(val) end
            TweenService:Create(fill, TweenInfo.new(0.08), {Size = UDim2.new(p, 0, 1, 0)}):Play()
            vLbl.Text = isFloat and string.format("%.2f", val) or tostring(val)
            callback(val)
        end
        
        tBtn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                drag = true update(i)
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i) end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then drag = false end
        end)
    end

    function TabAPI:CreateButton(title, color, callback)
        local btn = Make("TextButton", {Size = UDim2.new(1, 0, 0, 45), BackgroundColor3 = color or Theme.ItemBG, Text = title, TextColor3 = Theme.TextMain, Font = Fonts.Title, TextSize = 14}, page)
        Round(btn, 8) if not color then Stroke(btn, Theme.Border) end
        Ripple(btn)
        local hColor = color and Color3.new(math.clamp(color.R*1.2,0,1), math.clamp(color.G*1.2,0,1), math.clamp(color.B*1.2,0,1)) or Theme.HoverBG
        Hover(btn, color or Theme.ItemBG, hColor)
        btn.MouseButton1Click:Connect(callback)
    end
    
    TabAPI.Container = page
    return TabAPI
end

function Window:SelectTab(name)
    if GLOBALS.CurrentTab == name then return end
    GLOBALS.CurrentTab = name
    for tN, tB in pairs(self.TabBtns) do
        local p = self.Tabs[tN]
        if tN == name then
            TweenService:Create(tB, TweenInfo.new(0.2), {BackgroundTransparency = 0.8}):Play()
            TweenService:Create(tB:GetChildren()[2], TweenInfo.new(0.2), {TextColor3 = Theme.Primary}):Play()
            TweenService:Create(tB:GetChildren()[3], TweenInfo.new(0.2), {TextColor3 = Theme.Primary}):Play()
            p.Visible = true p.CanvasPosition = Vector2.new(0,0)
        else
            TweenService:Create(tB, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            TweenService:Create(tB:GetChildren()[2], TweenInfo.new(0.2), {TextColor3 = Theme.TextSub}):Play()
            TweenService:Create(tB:GetChildren()[3], TweenInfo.new(0.2), {TextColor3 = Theme.TextSub}):Play()
            p.Visible = false
        end
    end
end

