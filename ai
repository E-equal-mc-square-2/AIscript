    pLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pLayout.Parent = page
    
    UIUtils.Padding(page, 5, 20, 5, 10)
    
    self.Tabs[name] = page
    self.TabBtns[name] = btn
    
    btn.MouseEnter:Connect(function()
        if GUI_STATE.CurrentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.8}):Play()
            TweenService:Create(tLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextMain}):Play()
            TweenService:Create(iLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextMain}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if GUI_STATE.CurrentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            TweenService:Create(tLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextSub}):Play()
            TweenService:Create(iLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextSub}):Play()
        end
    end)
    
    btn.MouseButton1Click:Connect(function()
        self:SelectTab(name)
    end)
    
    return page
end

function UILib:SelectTab(name)
    if GUI_STATE.CurrentTab == name then return end
    GUI_STATE.CurrentTab = name
    for tName, tBtn in pairs(self.TabBtns) do
        local page = self.Tabs[tName]
        if tName == name then
            TweenService:Create(tBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0.85}):Play()
            TweenService:Create(tBtn:GetChildren()[2], TweenInfo.new(0.2), {TextColor3 = Theme.Primary}):Play()
            TweenService:Create(tBtn:GetChildren()[3], TweenInfo.new(0.2), {TextColor3 = Theme.Primary}):Play()
            page.Visible = true
            -- Subtle fade in for content
            page.CanvasPosition = Vector2.new(0,0)
        else
            TweenService:Create(tBtn, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            TweenService:Create(tBtn:GetChildren()[2], TweenInfo.new(0.2), {TextColor3 = Theme.TextSub}):Play()
            TweenService:Create(tBtn:GetChildren()[3], TweenInfo.new(0.2), {TextColor3 = Theme.TextSub}):Play()
            page.Visible = false
        end
    end
end

