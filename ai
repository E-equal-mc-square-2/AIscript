local function ToggleMenu()
    if GUI_STATE.IsAnimating then return end
    GUI_STATE.IsAnimating = true
    
    if not GUI_STATE.IsOpen then
        -- Open
        MainApp.Size = UDim2.new(0, 800, 0, 500)
        MainApp.BackgroundTransparency = 1
        MainApp.Visible = true
        
        -- Instantly reset transparencies
        for _, v in pairs(MainApp:GetDescendants()) do
            if v:IsA("Frame") or v:IsA("ScrollingFrame") then v.BackgroundTransparency = (v == Topbar or v == ContentArea or v == TabContainer or v.Name == "DropShadow") and 1 or 0
            elseif v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then v.TextTransparency = 0 v.BackgroundTransparency = (v.BackgroundTransparency == 1) and 1 or 0
            elseif v:IsA("UIStroke") then v.Transparency = 0 end
        end
        MainApp.BackgroundTransparency = 0
        
        local tw = TweenService:Create(MainApp, TweenInfo.new(CONFIG.AnimationSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 850, 0, 550)
        })
        tw:Play()
        tw.Completed:Wait()
        GUI_STATE.IsOpen = true
        GUI_STATE.IsAnimating = false
        
        if not GUI_STATE.CurrentTab then UILib:SelectTab("IDE Editor") end
    else
        -- Close
        local tw = TweenService:Create(MainApp, TweenInfo.new(CONFIG.AnimationSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 800, 0, 500)
        })
        
        for _, v in pairs(MainApp:GetDescendants()) do
            if v:IsA("Frame") or v:IsA("ScrollingFrame") then TweenService:Create(v, TweenInfo.new(CONFIG.AnimationSpeed), {BackgroundTransparency = 1}):Play()
            elseif v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then TweenService:Create(v, TweenInfo.new(CONFIG.AnimationSpeed), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
            elseif v:IsA("UIStroke") then TweenService:Create(v, TweenInfo.new(CONFIG.AnimationSpeed), {Transparency = 1}):Play()
            end
        end
        TweenService:Create(MainApp, TweenInfo.new(CONFIG.AnimationSpeed), {BackgroundTransparency = 1}):Play()
        
        tw:Play()
        tw.Completed:Wait()
        MainApp.Visible = false
        GUI_STATE.IsOpen = false
        GUI_STATE.IsAnimating = false
    end
end

