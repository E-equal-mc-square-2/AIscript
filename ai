        if CurrentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.9}):Play()
            TweenService:Create(iconLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextPrimary}):Play()
            TweenService:Create(txtLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextPrimary}):Play()
