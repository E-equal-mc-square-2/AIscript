local function ShowToast(title, message, color)
    color = color or Theme.Success
    
    local toast = Instance.new("Frame")
    toast.Size = UDim2.new(1, 0, 0, 65)
    toast.BackgroundColor3 = Theme.Sidebar
    toast.BackgroundTransparency = 1
    toast.ClipsDescendants = true
    toast.Parent = ToastContainer
    
    ApplyCorner(toast, 8)
    
    local stroke = ApplyStroke(toast, color, 1)
    stroke.Transparency = 1
    
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 4, 1, 0)
    indicator.BackgroundColor3 = color
    indicator.BorderSizePixel = 0
    indicator.BackgroundTransparency = 1
    indicator.Parent = toast
    
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(1, -20, 0, 20)
    titleLbl.Position = UDim2.new(0, 15, 0, 10)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.Font = Fonts.Bold
    titleLbl.TextSize = 14
    titleLbl.TextColor3 = color
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTransparency = 1
    titleLbl.Parent = toast
    
    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size = UDim2.new(1, -20, 0, 25)
    msgLbl.Position = UDim2.new(0, 15, 0, 32)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text = message
    msgLbl.Font = Fonts.Main
    msgLbl.TextSize = 12
    msgLbl.TextColor3 = Theme.TextMuted
    msgLbl.TextXAlignment = Enum.TextXAlignment.Left
    msgLbl.TextYAlignment = Enum.TextYAlignment.Top
    msgLbl.TextWrapped = true
    msgLbl.TextTransparency = 1
    msgLbl.Parent = toast
    
    -- Animate In
    local inInfo = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    TweenService:Create(toast, inInfo, {BackgroundTransparency = 0}):Play()
    TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0}):Play()
    TweenService:Create(indicator, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
    TweenService:Create(titleLbl, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(msgLbl, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    
    -- Queue Out
    task.delay(4, function()
        local outInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        local fade = TweenService:Create(toast, outInfo, {BackgroundTransparency = 1})
        
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
        TweenService:Create(indicator, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        TweenService:Create(titleLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(msgLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        
        fade:Play()
        fade.Completed:Wait()
        toast:Destroy()
    end)
end

