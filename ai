        Boolean = "#ff7b72"
    }
}

Lexer.Keywords = {["and"]=true, ["break"]=true, ["do"]=true, ["else"]=true, ["elseif"]=true, ["end"]=true, ["for"]=true, ["function"]=true, ["if"]=true, ["in"]=true, ["local"]=true, ["not"]=true, ["or"]=true, ["repeat"]=true, ["return"]=true, ["then"]=true, ["until"]=true, ["while"]=true, ["continue"]=true, ["export"]=true, ["type"]=true}
Lexer.Booleans = {["true"]=true, ["false"]=true, ["nil"]=true}
Lexer.BuiltIns = {["game"]=true, ["workspace"]=true, ["script"]=true, ["math"]=true, ["string"]=true, ["table"]=true, ["task"]=true, ["coroutine"]=true, ["os"]=true, ["debug"]=true, ["Color3"]=true, ["Vector3"]=true, ["Vector2"]=true, ["UDim2"]=true, ["UDim"]=true, ["CFrame"]=true, ["Instance"]=true, ["Enum"]=true, ["RaycastParams"]=true, ["print"]=true, ["warn"]=true, ["error"]=true, ["assert"]=true, ["typeof"]=true, ["pcall"]=true, ["xpcall"]=true, ["require"]=true, ["tick"]=true, ["wait"]=true, ["spawn"]=true, ["delay"]=true, ["loadstring"]=true, ["getgenv"]=true, ["request"]=true}
Lexer.Classes = {["Players"]=true, ["Lighting"]=true, ["ReplicatedStorage"]=true, ["StarterGui"]=true, ["HttpService"]=true, ["RunService"]=true, ["TweenService"]=true, ["UserInputService"]=true, ["Part"]=true, ["Model"]=true, ["Folder"]=true, ["ScreenGui"]=true, ["Frame"]=true, ["TextLabel"]=true, ["TextButton"]=true, ["TextBox"]=true, ["LocalPlayer"]=true, ["Humanoid"]=true}

local function EscapeHTML(str)
    local s = string.gsub(str, "&", "&amp;")
    s = string.gsub(s, "<", "&lt;")
    s = string.gsub(s, ">", "&gt;")
    return s
end

function Lexer.Highlight(source)
    if not source or source == "" then return "" end
    source = string.gsub(source, "\t", "    ")
    
    local lines = string.split(source, "\n")
    local output = {}
    
    for _, line in ipairs(lines) do
        local formatted = EscapeHTML(line)
        
        formatted = string.gsub(formatted, '("[^"]*")', function(s) return '<font color="'..Lexer.Colors.String..'">'..s..'</font>' end)
        formatted = string.gsub(formatted, "('[^']*')", function(s) return '<font color="'..Lexer.Colors.String..'">'..s..'</font>' end)
        formatted = string.gsub(formatted, "%f[%w%d%.](%d+%.?%d*)%f[^%w%d%.]", function(n) return '<font color="'..Lexer.Colors.Number..'">'..n..'</font>' end)
        formatted = string.gsub(formatted, ":(%a+%w*)", function(m) return ':<font color="'..Lexer.Colors.Method..'">'..m..'</font>' end)
        
        formatted = string.gsub(formatted, "%f[%a_][%a_][%w_]*%f[^%w_]", function(word)
            if Lexer.Keywords[word] then return '<font color="'..Lexer.Colors.Keyword..'">'..word..'</font>' end
            if Lexer.BuiltIns[word] then return '<font color="'..Lexer.Colors.BuiltIn..'">'..word..'</font>' end
            if Lexer.Classes[word] then return '<font color="'..Lexer.Colors.Class..'">'..word..'</font>' end
            if Lexer.Booleans[word] then return '<font color="'..Lexer.Colors.Boolean..'">'..word..'</font>' end
            return word
        end)
        
        local commentStart = string.find(formatted, "%-%-")
        if commentStart then
            local pre = string.sub(formatted, 1, commentStart - 1)
            local post = EscapeHTML(string.sub(line, string.find(line, "%-%-")))
            formatted = pre .. '<font color="'..Lexer.Colors.Comment..'">' .. post .. '</font>'
        end
        
        table.insert(output, formatted)
    end
    
    return table.concat(output, "\n")
end

