-- Flawless Orb Drag & Click Logic
local orbDragging = false
local orbDragStartPos = nil
local orbStartInputPos = nil
local orbClickStart = 0

Orb.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        orbDragging = true
        orbDragStartPos = Orb.Position
        orbStartInputPos = input.Position
        orbClickStart = tick()
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if orbDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - orbStartInputPos
        local newX = orbDragStartPos.X.Offset + delta.X
        local newY = orbDragStartPos.Y.Offset + delta.Y
        TweenService:Create(Orb, TweenInfo.new(0.08, Enum.EasingStyle.Sine), {
            Position = UDim2.new(orbDragStartPos.X.Scale, newX, orbDragStartPos.Y.Scale, newY)
        }):Play()
    end
end)

local UI_State = "Closed"
local function ToggleInterface()
    if UI_State == "Opening" or UI_State == "Closing" then return end
    
    if UI_State == "Closed" then
        UI_State = "Opening"
        MainWrapper.Size = UDim2.new(0.60, 0, 0.60, 0)
        MainWrapper.Visible = true
        MainFrame.BackgroundTransparency = 1
        
        -- Fix nested transparencies instantly
        for _,v in pairs(MainFrame:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then v.TextTransparency = 0
            elseif v:IsA("Frame") or v:IsA("ScrollingFrame") then v.BackgroundTransparency = 0
            elseif v:IsA("UIStroke") then v.Transparency = 0 end
        end
        
        -- Restore intentional hidden backgrounds
        ContentArea.BackgroundTransparency = 1
        TabContainer.BackgroundTransparency = 1
        IDE_CodeScroll.BackgroundTransparency = 1
        ChatScroll.BackgroundTransparency = 1
        ChatInput.BackgroundTransparency = 1
        VisScroll.BackgroundTransparency = 1
        ComScroll.BackgroundTransparency = 1
        SetScroll.BackgroundTransparency = 1
        
        for name, btn in pairs(TabButtons) do
            btn.BackgroundTransparency = (name == CurrentTab) and 0.8 or 1
            btn:GetChildren()[1].TextColor3 = (name == CurrentTab) and Theme.Accent or Theme.TextSecondary
            btn:GetChildren()[2].TextColor3 = (name == CurrentTab) and Theme.Accent or Theme.TextSecondary
        end
        
        local t = TweenService:Create(MainWrapper, TweenInfo.new(Config.AnimationDuration, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0.65, 0, 0.65, 0)
        })
        TweenService:Create(MainFrame, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
        t:Play()
        t.Completed:Wait()
        
        if not CurrentTab then TabButtons["IDE Editor"].MouseButton1Click:Fire() end
        UI_State = "Open"
        
    elseif UI_State == "Open" then
        UI_State = "Closing"
        local t = TweenService:Create(MainWrapper, TweenInfo.new(Config.AnimationDuration, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0.60, 0, 0.60, 0)
        })
        TweenService:Create(MainFrame, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
        for _,v in pairs(MainFrame:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then TweenService:Create(v, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
            elseif v:IsA("Frame") or v:IsA("ScrollingFrame") then TweenService:Create(v, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            elseif v:IsA("UIStroke") then TweenService:Create(v, TweenInfo.new(0.2), {Transparency = 1}):Play() end
        end
        t:Play()
        t.Completed:Wait()
        MainWrapper.Visible = false
        UI_State = "Closed"
    end
end

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if orbDragging then
            orbDragging = false
            -- If time elapsed is short, and distance moved is small, it's a click.
            local timeElapsed = tick() - orbClickStart
            local distance = (input.Position - orbStartInputPos).Magnitude
            if timeElapsed < 0.3 and distance < 10 then
                ToggleInterface()
            end
        end
    end
end)

CloseBtn.MouseButton1Click:Connect(ToggleInterface)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Config.ToggleKey then
        ToggleInterface()
    end
end)

