        OrbDragging = true
        OrbStartPos = Orb.Position
        OrbStartInput = input.Position
        OrbIsClick = true
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if AppDragging then
            local delta = input.Position - AppStartInputPos
            SpringX.Target = AppDragStartPos.X.Offset + delta.X
            SpringY.Target = AppDragStartPos.Y.Offset + delta.Y
        elseif OrbDragging then
            local delta = input.Position - OrbStartInput
            if delta.Magnitude > 5 then
                OrbIsClick = false
            end
            local t = TweenService:Create(Orb, TweenInfo.new(0.08, Enum.EasingStyle.Sine), {
                Position = UDim2.new(OrbStartPos.X.Scale, OrbStartPos.X.Offset + delta.X, OrbStartPos.Y.Scale, OrbStartPos.Y.Offset + delta.Y)
            })
            t:Play()
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        AppDragging = false
        if OrbDragging and OrbIsClick then
            ToggleUI()
        end
        OrbDragging = false
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if AppDragging or math.abs(SpringX.Velocity) > 0.1 or math.abs(SpringY.Velocity) > 0.1 then
        if MainApp.Visible then
            local nx = SpringX:Update(dt)
            local ny = SpringY:Update(dt)
            MainApp.Position = UDim2.new(AppDragStartPos.X.Scale, nx, AppDragStartPos.Y.Scale, ny)
        end
    end
end)

-- The State Machine Toggle Logic
local UI_State = "Closed"

function ToggleUI()
    if UI_State == "Opening" or UI_State == "Closing" then return end
    
    if UI_State == "Closed" then
        UI_State = "Opening"
        MainApp.Size = UDim2.new(0, 900, 0, 580)
        MainApp.BackgroundTransparency = 1
        MainApp.Visible = true
        
        -- Instantly reveal text/borders for fade-in effect
        for _, v in pairs(MainApp:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
                v.TextTransparency = 0
            elseif v:IsA("Frame") or v:IsA("ScrollingFrame") then
                v.BackgroundTransparency = 0
            elseif v:IsA("UIStroke") then
                v.Transparency = 0
            elseif v:IsA("ImageLabel") then
                v.ImageTransparency = 0.5
            end
        end
        
        -- Restore specific structural transparencies
        Sidebar.BackgroundTransparency = 0
        ContentArea.BackgroundTransparency = 1
        Topbar.BackgroundTransparency = 1
        ChatScroll.BackgroundTransparency = 1
        CodeScroll.BackgroundTransparency = 1
        LineNumScroll.BackgroundTransparency = 1
        ConScroll.BackgroundTransparency = 1
        TabContainer.BackgroundTransparency = 1
        UtilScroll.BackgroundTransparency = 1
        QuickPromptCont.BackgroundTransparency = 1
        ESPScroll.BackgroundTransparency = 1
        CombatScroll.BackgroundTransparency = 1
        
        for name, btn in pairs(TabBtns) do
            if name == CurrentTab then
                btn.BackgroundTransparency = 0.8
                btn:GetChildren()[2].TextColor3 = Theme.Accent
                btn:GetChildren()[3].TextColor3 = Theme.Accent
            else
                btn.BackgroundTransparency = 1
                btn:GetChildren()[2].TextColor3 = Theme.TextMuted
                btn:GetChildren()[3].TextColor3 = Theme.TextMuted
            end
        end
        
        local animInfo = TweenInfo.new(CONFIG.AnimationSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        local t = TweenService:Create(MainApp, animInfo, {Size = UDim2.new(0, 950, 0, 620), BackgroundTransparency = 0})
        t:Play()
        t.Completed:Wait()
        
        if not CurrentTab then
            TabBtns["IDE Editor"].MouseButton1Click:Fire()
        end
        
        UI_State = "Open"
        
    elseif UI_State == "Open" then
        UI_State = "Closing"
        
        local animInfo = TweenInfo.new(CONFIG.AnimationSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        local t = TweenService:Create(MainApp, animInfo, {Size = UDim2.new(0, 900, 0, 580), BackgroundTransparency = 1})
        
        for _, v in pairs(MainApp:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
                TweenService:Create(v, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
            elseif v:IsA("Frame") or v:IsA("ScrollingFrame") then
                TweenService:Create(v, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            elseif v:IsA("UIStroke") then
                TweenService:Create(v, TweenInfo.new(0.2), {Transparency = 1}):Play()
            elseif v:IsA("ImageLabel") then
                TweenService:Create(v, TweenInfo.new(0.2), {ImageTransparency = 1}):Play()
            end
        end
        
        t:Play()
        t.Completed:Wait()
        MainApp.Visible = false
        UI_State = "Closed"
    end
end

