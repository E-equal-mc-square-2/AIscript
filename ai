local function HandleScale()
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local x = cam.ViewportSize.X
    local y = cam.ViewportSize.Y
    if x < 900 or y < 600 then
        local ratio = math.min(x / 950, y / 650)
        AppScale.Scale = ratio
        GUI_STATE.ResolutionScale = ratio
    else
        AppScale.Scale = 1
        GUI_STATE.ResolutionScale = 1
    end
