    valLbl.Size = UDim2.new(0, 40, 0, 20)
    valLbl.Position = UDim2.new(1, -55, 0, 10)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = tostring(default)
    valLbl.TextColor3 = Theme.Primary
    valLbl.Font = Fonts.Code
    valLbl.TextSize = 13
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.Parent = cont
    
    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1, -30, 0, 6)
    trackBg.Position = UDim2.new(0, 15, 0, 42)
    trackBg.BackgroundColor3 = Theme.AppBG
    trackBg.Parent = cont
    UIUtils.Corner(trackBg, 3)
    UIUtils.Stroke(trackBg, Theme.Border)
    
    local fill = Instance.new("Frame")
    local startPct = (default - min) / (max - min)
    fill.Size = UDim2.new(startPct, 0, 1, 0)
    fill.BackgroundColor3 = Theme.Primary
    fill.Parent = trackBg
    UIUtils.Corner(fill, 3)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(1, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.Parent = fill
    UIUtils.Corner(knob, 7)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 20)
    btn.Position = UDim2.new(0, 0, 0, -10)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = trackBg
    
    local dragging = false
    local function update(input)
        local pct = math.clamp((input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * pct
        if not isFloat then val = math.floor(val) end
        TweenService:Create(fill, TweenInfo.new(0.1), {Size = UDim2.new(pct, 0, 1, 0)}):Play()
        valLbl.Text = isFloat and string.format("%.1f", val) or tostring(val)
        callback(val)
    end
    
    btn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(i)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            update(i)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

