local function BuildSlider(parent, text, min, max, default, callback)
    local cont = UI.Create("Frame", {
        Size = UDim2.new(1, -10, 0, 55),
        BackgroundColor3 = Theme.ElementBG,
        Parent = parent
    })
    UI.Round(cont, 6)
    UI.Stroke(cont, Theme.Border)
    
    UI.Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 15, 0, 8),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Theme.TextPrimary,
        Font = Fonts.Header,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = cont
    })
    
    local valLbl = UI.Create("TextLabel", {
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(1, -65, 0, 8),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = Theme.Accent,
        Font = Fonts.Code,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = cont
    })
    
    local track = UI.Create("TextButton", {
        Size = UDim2.new(1, -30, 0, 6),
        Position = UDim2.new(0, 15, 0, 35),
        BackgroundColor3 = Theme.Background,
        Text = "",
        AutoButtonColor = false,
        Parent = cont
    })
    UI.Round(track, 3)
    UI.Stroke(track, Theme.Border)
    
    local fill = UI.Create("Frame", {
        Size = UDim2.new((default - min)/(max - min), 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Parent = track
    })
    UI.Round(fill, 3)
    
    local dragging = false
    local function update(input)
        local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pct)
        TweenService:Create(fill, TweenInfo.new(0.1), {Size = UDim2.new(pct, 0, 1, 0)}):Play()
        valLbl.Text = tostring(val)
        callback(val)
    end
    
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(i) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

