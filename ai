local CurrentTab = nil

local function RegisterTab(name, icon)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -30, 0, 45)
    btn.BackgroundColor3 = Theme.Accent
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = TabContainer
    
    ApplyCorner(btn, 8)
    CreateRipple(btn)
    
    local iLbl = Instance.new("TextLabel")
    iLbl.Size = UDim2.new(0, 40, 1, 0)
    iLbl.BackgroundTransparency = 1
    iLbl.Text = icon
    iLbl.TextColor3 = Theme.TextMuted
    iLbl.Font = Fonts.Main
    iLbl.TextSize = 18
    iLbl.Parent = btn
    
    local tLbl = Instance.new("TextLabel")
    tLbl.Size = UDim2.new(1, -40, 1, 0)
    tLbl.Position = UDim2.new(0, 40, 0, 0)
    tLbl.BackgroundTransparency = 1
    tLbl.Text = name
    tLbl.TextColor3 = Theme.TextMuted
    tLbl.Font = Fonts.Bold
    tLbl.TextSize = 14
    tLbl.TextXAlignment = Enum.TextXAlignment.Left
    tLbl.Parent = btn
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Visible = false
    frame.Parent = ContentArea
    
    Tabs[name] = frame
    TabBtns[name] = btn
    
    btn.MouseEnter:Connect(function()
        if CurrentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 0.9}):Play()
            TweenService:Create(tLbl, TweenInfo.new(0.2), {TextColor3 = Theme.Text}):Play()
            TweenService:Create(iLbl, TweenInfo.new(0.2), {TextColor3 = Theme.Text}):Play()
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if CurrentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            TweenService:Create(tLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextMuted}):Play()
            TweenService:Create(iLbl, TweenInfo.new(0.2), {TextColor3 = Theme.TextMuted}):Play()
        end
    end)
    
    btn.MouseButton1Click:Connect(function()
        for tName, tBtn in pairs(TabBtns) do
            if tName == name then
                CurrentTab = name
                tBtn.BackgroundTransparency = 0.8
                tBtn:GetChildren()[2].TextColor3 = Theme.Accent
                tBtn:GetChildren()[3].TextColor3 = Theme.Accent
                Tabs[tName].Visible = true
            else
                tBtn.BackgroundTransparency = 1
                tBtn:GetChildren()[2].TextColor3 = Theme.TextMuted
                tBtn:GetChildren()[3].TextColor3 = Theme.TextMuted
                Tabs[tName].Visible = false
            end
        end
    end)
    
    return frame
end

