    IDE_LineNums.CanvasSize = UDim2.new(0, 0, 0, canvasY)
    
    SyntaxHighlighter.Size = UDim2.new(1, -20, 0, bounds.Y + 20)
    CodeInputBox.Size = UDim2.new(1, -20, 0, bounds.Y + 20)
    LineNumText.Size = UDim2.new(1, -10, 0, bounds.Y + 20)
end

