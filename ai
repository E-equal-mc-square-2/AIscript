function Sovereign.Notify(title, desc, color, duration)
    color = color or Theme.Primary
    duration = duration or 5
    
    local notif = Make("Frame", {Size = UDim2.new(1, 0, 0, 75), BackgroundColor3 = Theme.SidebarBG, BackgroundTransparency = 1, ClipsDescendants = true}, ToastContainer)
    Round(notif, 8)
    local stroke = Stroke(notif, color, 1) stroke.Transparency = 1
    
    local line = Make("Frame", {Size = UDim2.new(0, 4, 1, 0), BackgroundColor3 = color, BorderSizePixel = 0, BackgroundTransparency = 1}, notif)
    local tLbl = Make("TextLabel", {Size = UDim2.new(1, -20, 0, 25), Position = UDim2.new(0, 15, 0, 5), BackgroundTransparency = 1, Text = title, TextColor3 = color, Font = Fonts.Title, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, TextTransparency = 1}, notif)
    local dLbl = Make("TextLabel", {Size = UDim2.new(1, -20, 0, 40), Position = UDim2.new(0, 15, 0, 30), BackgroundTransparency = 1, Text = desc, TextColor3 = Theme.TextSub, Font = Fonts.Body, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true, TextTransparency = 1}, notif)
    
    local inInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    TweenService:Create(notif, inInfo, {BackgroundTransparency = 0}):Play()
    TweenService:Create(stroke, TweenInfo.new(0.4), {Transparency = 0.5}):Play()
    TweenService:Create(line, TweenInfo.new(0.4), {BackgroundTransparency = 0}):Play()
    TweenService:Create(tLbl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    TweenService:Create(dLbl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    
    task.delay(duration, function()
        local outInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        local tw = TweenService:Create(notif, outInfo, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1})
        TweenService:Create(stroke, outInfo, {Transparency = 1}):Play()
        TweenService:Create(line, outInfo, {BackgroundTransparency = 1}):Play()
        TweenService:Create(tLbl, outInfo, {TextTransparency = 1}):Play()
        TweenService:Create(dLbl, outInfo, {TextTransparency = 1}):Play()
        tw:Play() tw.Completed:Wait() notif:Destroy()
    end)
end

