                    local headPos = head and cam:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or cam:WorldToViewportPoint(root.Position + Vector3.new(0, 2, 0))
                    local legPos = cam:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
                    
                    local height = math.abs(headPos.Y - legPos.Y)
                    local width = height * 0.6
                    
                    local boxX = rootPos.X - (width / 2)
                    local boxY = headPos.Y
                    
                    if SaveData.ESPBoxes then
                        cache.Box.Size = UDim2.new(0, width, 0, height)
                        cache.Box.Position = UDim2.new(0, boxX, 0, boxY)
                        cache.Box.Visible = true
                    else
                        cache.Box.Visible = false
                    end
                    
                    if SaveData.ESPNames then
                        cache.Name.Position = UDim2.new(0, rootPos.X - 50, 0, boxY - 20)
                        cache.Name.Size = UDim2.new(0, 100, 0, 15)
                        cache.Name.Visible = true
                    else
                        cache.Name.Visible = false
                    end
                    
                    if SaveData.ESPHealth then
                        local hpPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        cache.HealthBg.Size = UDim2.new(0, 3, 0, height)
                        cache.HealthBg.Position = UDim2.new(0, boxX - 6, 0, boxY)
                        cache.HealthBg.Visible = true
                        
                        cache.HealthFill.Size = UDim2.new(1, 0, hpPercent, 0)
                        cache.HealthFill.Position = UDim2.new(0, 0, 1 - hpPercent, 0)
                        
                        -- Color gradient based on HP
                        cache.HealthFill.BackgroundColor3 = Color3.new(1 - hpPercent, hpPercent, 0)
                    else
                        cache.HealthBg.Visible = false
                    end
                else
                    cache.Box.Visible = false
                    cache.Name.Visible = false
                    cache.HealthBg.Visible = false
                end
            else
                cache.Box.Visible = false
                cache.Name.Visible = false
                cache.HealthBg.Visible = false
            end
        end
    end
end)

