--// FLAWLESS DRAGGING LOGIC (With Drag vs Click Detection)
local function MakeDraggable(dragFrame, targetFrame, isOrbToggle)
    local dragging, dragStart, startPos
    local dragThreshold = 5
    local isClick = true

    dragFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            isClick = true
            dragStart = input.Position
            startPos = targetFrame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            if delta.Magnitude > dragThreshold then
                isClick = false -- Distance exceeded, cancel the click
            end
            local goal = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            TweenService:Create(targetFrame, TweenInfo.new(0.08, Enum.EasingStyle.Sine), {Position = goal}):Play()
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging and isClick and isOrbToggle then
                -- Toggle UI State
                if Main.Visible then
                    TweenService:Create(Main.UIScale, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0.8}):Play()
                    local t = TweenService:Create(Main, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 1})
                    t:Play()
                    t.Completed:Wait()
                    Main.Visible = false
                else
                    Main.Visible = true
                    TweenService:Create(Main.UIScale, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
                    TweenService:Create(Main, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {GroupTransparency = 0}):Play()
                end
            end
            dragging = false
        end
    end)
end

