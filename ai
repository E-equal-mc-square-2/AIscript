    {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"}
}

local function GetLine(name, parent)
    local l = Make("Frame", {Name = name, BackgroundColor3 = ESP.Color, BorderSizePixel = 0, AnchorPoint = Vector2.new(0.5, 0.5), Visible = false, ZIndex = 1}, parent)
    return l
end

local function UpdateESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        
        if not GLOBALS.ESPCache[p] then
            GLOBALS.ESPCache[p] = {
                Box = Make("Frame", {BackgroundTransparency = 1, Visible = false}, ESPFolder),
                Name = Make("TextLabel", {BackgroundTransparency = 1, TextColor3 = Color3.new(1,1,1), Font = Fonts.Title, TextSize = 11, TextStrokeTransparency = 0, Visible = false}, ESPFolder),
                HealthBG = Make("Frame", {BackgroundColor3 = Color3.new(0,0,0), BorderSizePixel = 0, Visible = false}, ESPFolder),
                HealthFill = Make("Frame", {BackgroundColor3 = Theme.Success, BorderSizePixel = 0}, nil),
                Tracer = GetLine("Tracer", ESPFolder),
                Bones = {}
            }
            GLOBALS.ESPCache[p].HealthFill.Parent = GLOBALS.ESPCache[p].HealthBG
            Stroke(GLOBALS.ESPCache[p].Box, ESP.Color, 1)
            for i=1, #BoneMap do GLOBALS.ESPCache[p].Bones[i] = GetLine("Bone"..i, ESPFolder) end
        end
        
        local cache = GLOBALS.ESPCache[p]
        local char = p.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if ESP.Master and char and root and hum and hum.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                local top, _ = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                local bot, _ = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
                local h = bot.Y - top.Y
                local w = h / 2
                local x = top.X - (w / 2)
                local y = top.Y
                
                -- Box
                cache.Box.Size = UDim2.new(0, w, 0, h)
                cache.Box.Position = UDim2.new(0, x, 0, y)
                cache.Box.Visible = ESP.Box
                cache.Box.UIStroke.Color = ESP.Color
                
                -- Name
                cache.Name.Text = p.Name
                cache.Name.Size = UDim2.new(0, w, 0, 15)
                cache.Name.Position = UDim2.new(0, x, 0, y - 18)
                cache.Name.Visible = ESP.Name
                
                -- Health
                if ESP.Health then
                    local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    cache.HealthBG.Size = UDim2.new(0, 3, 0, h)
                    cache.HealthBG.Position = UDim2.new(0, x - 7, 0, y)
                    cache.HealthFill.Size = UDim2.new(1, 0, hp, 0)
                    cache.HealthFill.Position = UDim2.new(0, 0, 1 - hp, 0)
                    cache.HealthFill.BackgroundColor3 = Color3.new(1 - hp, hp, 0)
                    cache.HealthBG.Visible = true
                else cache.HealthBG.Visible = false end
                
                -- Tracer
                if ESP.Tracer then
                    local origin = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    local target = Vector2.new(pos.X, pos.Y + (h/2))
                    local dir = target - origin
                    local len = dir.Magnitude
                    local angle = math.atan2(dir.Y, dir.X)
                    cache.Tracer.Size = UDim2.new(0, len, 0, 1)
                    cache.Tracer.Position = UDim2.new(0, origin.X + dir.X/2, 0, origin.Y + dir.Y/2)
                    cache.Tracer.Rotation = math.deg(angle)
                    cache.Tracer.BackgroundColor3 = ESP.Color
                    cache.Tracer.Visible = true
                else cache.Tracer.Visible = false end
                
                -- Skeleton
                if ESP.Skeleton then
                    for i, pair in ipairs(BoneMap) do
                        local p1 = char:FindFirstChild(pair[1])
                        local p2 = char:FindFirstChild(pair[2])
                        if p1 and p2 then
                            local w1, s1 = Camera:WorldToViewportPoint(p1.Position)
                            local w2, s2 = Camera:WorldToViewportPoint(p2.Position)
                            if s1 and s2 then
                                local v1 = Vector2.new(w1.X, w1.Y)
                                local v2 = Vector2.new(w2.X, w2.Y)
                                local dir = v2 - v1
                                local len = dir.Magnitude
                                local ang = math.atan2(dir.Y, dir.X)
                                cache.Bones[i].Size = UDim2.new(0, len, 0, 1)
                                cache.Bones[i].Position = UDim2.new(0, v1.X + dir.X/2, 0, v1.Y + dir.Y/2)
                                cache.Bones[i].Rotation = math.deg(ang)
                                cache.Bones[i].BackgroundColor3 = ESP.Color
                                cache.Bones[i].Visible = true
                            else cache.Bones[i].Visible = false end
                        else cache.Bones[i].Visible = false end
                    end
                else
                    for i=1, #BoneMap do cache.Bones[i].Visible = false end
                end
                
                continue
            end
        end
        
        -- Hide All
        cache.Box.Visible = false
        cache.Name.Visible = false
        cache.HealthBG.Visible = false
        cache.Tracer.Visible = false
        for i=1, #BoneMap do cache.Bones[i].Visible = false end
    end
end
RunService.RenderStepped:Connect(UpdateESP)

