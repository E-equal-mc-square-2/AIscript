--// AI EXECUTION ENGINE
local function CallGemini(query, isCode)
    if CONFIG.ApiKey == "" then return "ERROR: No API Key Set." end
    local systemPrompt = isCode and "You are an elite Roblox Luau exploit engineer. Output ONLY raw, functional Luau code based on the request. No markdown outside of ```lua." or "You are Sovereign Titan V8. An extremely intelligent assistant for Roblox."
    local url = "https://generativelanguage.googleapis.com/v1beta/models/"..CONFIG.Model..":generateContent?key="..CONFIG.ApiKey
    
    local payload = {
        contents = {{ role = "user", parts = {{text = systemPrompt .. "\n\nRequest: " .. query}} }}
    }

    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)

    if success and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        local result = data.candidates[1].content.parts[1].text
        
        -- Safely extract Lua code if it wrapped it in markdown
        if isCode then
            local match = result:match("```lua\n?(.-)```") or result:match("```\n?(.-)```")
            return match or result
        end
        return result
    end
    return "API Request Failed. Check your Key and Connection."
end

