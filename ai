local UI = {}

function UI.Create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props) do
        if type(k) == "string" then inst[k] = v else v.Parent = inst end
    end
    return inst
end

function UI.Round(obj, radius) return UI.Create("UICorner", { CornerRadius = UDim.new(0, radius), Parent = obj }) end
function UI.Stroke(obj, color, thickness) return UI.Create("UIStroke", { Color = color, Thickness = thickness or 1, Parent = obj }) end
function UI.Gradient(obj, color1, color2, rotation) return UI.Create("UIGradient", { Color = ColorSequence.new{ColorSequenceKeypoint.new(0, color1), ColorSequenceKeypoint.new(1, color2)}, Rotation = rotation or 0, Parent = obj }) end

function UI.DropShadow(obj, size, transparency)
    return UI.Create("ImageLabel", {
        Name = "DropShadow", BackgroundTransparency = 1, Image = "rbxassetid://6015045625", ImageColor3 = Color3.fromRGB(0, 0, 0), ImageTransparency = transparency or 0.5,
        ScaleType = Enum.ScaleType.Slice, SliceCenter = Rect.new(9, 9, 21, 21), Size = UDim2.new(1, size*2, 1, size*2), Position = UDim2.new(0, -size, 0, -size), ZIndex = obj.ZIndex - 1, Parent = obj
    })
end

function UI.Tween(obj, properties, time, style, direction)
    local tween = TweenService:Create(obj, TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quart, direction or Enum.EasingDirection.Out), properties)
    tween:Play() return tween
end

function UI.Ripple(button)
    local Container = UI.Create("Frame", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, ClipsDescendants = true, ZIndex = button.ZIndex + 1, Parent = button })
    UI.Round(Container, button:FindFirstChild("UICorner") and button.UICorner.CornerRadius.Offset or 0)
    button.MouseButton1Down:Connect(function()
        local mousePos = UserInputService:GetMouseLocation() - Vector2.new(0, 36)
        local Circle = UI.Create("Frame", { Position = UDim2.new(0, mousePos.X - button.AbsolutePosition.X, 0, mousePos.Y - button.AbsolutePosition.Y), Size = UDim2.new(0, 0, 0, 0), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.6, ZIndex = Container.ZIndex + 1, Parent = Container })
        UI.Round(Circle, 999)
        local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.5
        UI.Tween(Circle, {Size = UDim2.new(0, size, 0, size), BackgroundTransparency = 1}, 0.5, Enum.EasingStyle.Sine)
        task.delay(0.5, function() Circle:Destroy() end)
    end)
end

-- [ FLAWLESS DRAG LOGIC ]
function UI.MakeDraggableSmooth(frame, dragHandle)
    local dragging = false
    local dragStart, startPos
    
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            -- Smooth linear tweening to strictly follow the mouse without skipping
            UI.Tween(frame, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.08, Enum.EasingStyle.Linear)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

