local SyntaxColors = {Keyword="#F86D7C", Function="#82AAFF", String="#C3E88D", Number="#F78C6C", Comment="#676E95"}
local LuaKeywords = {"and", "break", "do", "else", "elseif", "end", "false", "for", "function", "if", "in", "local", "nil", "not", "or", "repeat", "return", "then", "true", "until", "while", "task.wait", "task.spawn"}

local function HighlightLuaCode(codeStr)
    codeStr = codeStr:gsub("<", "&lt;"):gsub(">", "&gt;")
    codeStr = codeStr:gsub('"(.-)"', '<font color="'..SyntaxColors.String..'">"%1"</font>')
    codeStr = codeStr:gsub("'(.-)'", '<font color="'..SyntaxColors.String..'">\'%1\'</font>')
    codeStr = codeStr:gsub("(%W)(%d+%.?%d*)(%W)", '%1<font color="'..SyntaxColors.Number..'">%2</font>%3')
    codeStr = codeStr:gsub("(%-%-[^\n]*)", '<font color="'..SyntaxColors.Comment..'">%1</font>')
    for _, kw in pairs(LuaKeywords) do
        codeStr = codeStr:gsub("(%W)("..kw..")(%W)", '%1<font color="'..SyntaxColors.Keyword..'">%2</font>%3')
        codeStr = codeStr:gsub("^("..kw..")(%W)", '<font color="'..SyntaxColors.Keyword..'">%1</font>%2')
        codeStr = codeStr:gsub("(%W)("..kw..")$", '%1<font color="'..SyntaxColors.Keyword..'">%2</font>')
    end
    codeStr = codeStr:gsub("([%w_]+)%s*(%()", '<font color="'..SyntaxColors.Function..'">%1</font>%2')
    return codeStr
end

