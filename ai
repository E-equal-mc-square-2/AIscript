local function EscapeRichText(str)
    local replaced = str:gsub("&", "&amp;")
    replaced = replaced:gsub("<", "&lt;")
    replaced = replaced:gsub(">", "&gt;")
    return replaced
end

function Lexer.Highlight(source)
    if not source or source == "" then return "" end
    
    -- Fix tab alignment for visual parity
    source = source:gsub("\t", "    ")
    
    local lines = string.split(source, "\n")
    local outputLines = {}
    
    for _, line in ipairs(lines) do
        local formatted = EscapeRichText(line)
        
        -- 1. Strings
        formatted = formatted:gsub('("[^"]*")', function(s)
            return '<font color="' .. Lexer.Colors.String .. '">' .. s .. '</font>'
        end)
        formatted = formatted:gsub("('[^']*')", function(s)
            return '<font color="' .. Lexer.Colors.String .. '">' .. s .. '</font>'
        end)
        
        -- 2. Numbers
        formatted = formatted:gsub("%f[%w%d%.](%d+%.?%d*)%f[^%w%d%.]", function(n)
            return '<font color="' .. Lexer.Colors.Number .. '">' .. n .. '</font>'
        end)
        
        -- 3. Methods
        formatted = formatted:gsub(":(%a+%w*)", function(m)
            return ':<font color="' .. Lexer.Colors.Method .. '">' .. m .. '</font>'
        end)
        
        -- 4. Keywords, BuiltIns, Classes, Booleans
        formatted = formatted:gsub("%f[%a_][%a_][%w_]*%f[^%w_]", function(word)
            if Lexer.Keywords[word] then
                return '<font color="' .. Lexer.Colors.Keyword .. '">' .. word .. '</font>'
            elseif Lexer.BuiltIns[word] then
                return '<font color="' .. Lexer.Colors.BuiltIn .. '">' .. word .. '</font>'
            elseif Lexer.Classes[word] then
                return '<font color="' .. Lexer.Colors.Class .. '">' .. word .. '</font>'
            elseif Lexer.Booleans[word] then
                return '<font color="' .. Lexer.Colors.Boolean .. '">' .. word .. '</font>'
            elseif word == "self" then
                return '<font color="' .. Lexer.Colors.Self .. '">' .. word .. '</font>'
            end
            return word
        end)
        
        -- 5. Comments
        local commentStart = formatted:find("%-%-")
        if commentStart then
            local preComment = formatted:sub(1, commentStart - 1)
            local rawComment = line:sub(line:find("%-%-"))
            local escapedComment = EscapeRichText(rawComment)
            formatted = preComment .. '<font color="' .. Lexer.Colors.Comment .. '">' .. escapedComment .. '</font>'
        end
        
        table.insert(outputLines, formatted)
    end
    
    return table.concat(outputLines, "\n")
end

