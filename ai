local function UpdateESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        if not ESPCache[player] then ESPCache[player] = CreateESPData(player) end
        local cache = ESPCache[player]
        
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        local isAlive = hum and hum.Health > 0
        local isEnemy = not ESPSettings.TeamCheck or player.Team ~= LocalPlayer.Team
        
        if ESPSettings.Master and char and root and isAlive and isEnemy then
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                local rootTop, _ = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                local rootBot, _ = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
                
                local height = rootBot.Y - rootTop.Y
                local width = height / 1.8
                local x = rootTop.X - (width / 2)
                local y = rootTop.Y
                
                local dist = math.floor((Camera.CFrame.Position - root.Position).Magnitude)
                
                -- Box
                cache.Box.Size = UDim2.new(0, width, 0, height)
                cache.Box.Position = UDim2.new(0, x, 0, y)
                cache.Box.Visible = ESPSettings.Boxes
                cache.BoxStroke.Color = ESPSettings.Color
                
                -- Name
                cache.Name.Text = player.Name
                cache.Name.Size = UDim2.new(0, width, 0, 15)
                cache.Name.Position = UDim2.new(0, x, 0, y - 18)
                cache.Name.Visible = ESPSettings.Names
                
                -- Distance
                cache.Dist.Text = "["..dist.."s]"
                cache.Dist.Size = UDim2.new(0, width, 0, 15)
                cache.Dist.Position = UDim2.new(0, x, 0, y + height + 2)
                cache.Dist.Visible = ESPSettings.Distance
                
                -- Health
                if ESPSettings.Health then
                    local hpPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    cache.HealthBG.Size = UDim2.new(0, 3, 0, height)
                    cache.HealthBG.Position = UDim2.new(0, x - 6, 0, y)
                    cache.HealthFill.Size = UDim2.new(1, 0, hpPct, 0)
                    cache.HealthFill.Position = UDim2.new(0, 0, 1 - hpPct, 0)
                    cache.HealthFill.BackgroundColor3 = Color3.new(1 - hpPct, hpPct, 0)
                    cache.HealthBG.Visible = true
                else
                    cache.HealthBG.Visible = false
                end
                
                -- Tracer Logic (Math rotation)
                if ESPSettings.Tracers then
                    local origin = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    local target = Vector2.new(pos.X, pos.Y + (height/2))
                    local delta = target - origin
                    local length = delta.Magnitude
                    local angle = math.atan2(delta.Y, delta.X)
                    
                    cache.Tracer.Size = UDim2.new(0, length, 0, 1)
                    cache.Tracer.Position = UDim2.new(0, origin.X + delta.X/2, 0, origin.Y + delta.Y/2)
                    cache.Tracer.Rotation = math.deg(angle)
                    cache.Tracer.BackgroundColor3 = ESPSettings.Color
                    cache.Tracer.Visible = true
                else
                    cache.Tracer.Visible = false
                end
                
                continue
            end
        end
        
        -- Hide if not met
        cache.Box.Visible = false
        cache.Name.Visible = false
        cache.Dist.Visible = false
        cache.HealthBG.Visible = false
        cache.Tracer.Visible = false
    end
end
