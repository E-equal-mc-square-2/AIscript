-- [3] KINEMATIC SPRING PHYSICS ENGINE
--===================================================================================================
local Spring = {}
Spring.__index = Spring

function Spring.new(mass, damping, stiffness)
    local self = setmetatable({}, Spring)
    self.Target = Vector2.new()
    self.Position = Vector2.new()
    self.Velocity = Vector2.new()
    self.Mass = mass or 1
    self.Damping = damping or 1
    self.Stiffness = stiffness or 1
    return self
end

function Spring:Update(dt)
    local displacement = self.Position - self.Target
    local springForce = displacement * -self.Stiffness
    local damperForce = self.Velocity * -self.Damping
    local acceleration = (springForce + damperForce) / self.Mass
    
    self.Velocity = self.Velocity + acceleration * dt
    self.Position = self.Position + self.Velocity * dt
    return self.Position
end

