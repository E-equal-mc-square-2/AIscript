local function EscapeHTML(str)
    return str:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
end

function Lexer.Highlight(source)
    if not source or source == "" then return "" end
    source = source:gsub("\t", "    ")
    local lines = string.split(source, "\n")
    local out = {}
    
    for _, line in ipairs(lines) do
        local fmt = EscapeHTML(line)
        -- Strings
        fmt = fmt:gsub('("[^"]*")', function(s) return '<font color="'..Lexer.Colors.String..'">'..s..'</font>' end)
        fmt = fmt:gsub("('[^']*')", function(s) return '<font color="'..Lexer.Colors.String..'">'..s..'</font>' end)
        -- Numbers
        fmt = fmt:gsub("%f[%w%d%.](%d+%.?%d*)%f[^%w%d%.]", function(n) return '<font color="'..Lexer.Colors.Number..'">'..n..'</font>' end)
        -- Methods
        fmt = fmt:gsub(":(%a+%w*)", function(m) return ':<font color="'..Lexer.Colors.Method..'">'..m..'</font>' end)
        -- Keywords / Builtins
        fmt = fmt:gsub("%f[%a_][%a_][%w_]*%f[^%w_]", function(word)
            if Lexer.Keywords[word] then return '<font color="'..Lexer.Colors.Keyword..'">'..word..'</font>'
            elseif Lexer.BuiltIns[word] then return '<font color="'..Lexer.Colors.BuiltIn..'">'..word..'</font>'
            elseif Lexer.Classes[word] then return '<font color="'..Lexer.Colors.Class..'">'..word..'</font>'
            elseif Lexer.Booleans[word] then return '<font color="'..Lexer.Colors.Boolean..'">'..word..'</font>'
            elseif word == "self" then return '<font color="'..Lexer.Colors.Self..'">'..word..'</font>'
            end
            return word
        end)
        -- Comments
        local cStart = fmt:find("%-%-")
        if cStart then
            local pre = fmt:sub(1, cStart - 1)
            local raw = line:sub(line:find("%-%-"))
            fmt = pre .. '<font color="'..Lexer.Colors.Comment..'">'..EscapeHTML(raw)..'</font>'
        end
        table.insert(out, fmt)
    end
    return table.concat(out, "\n")
end

