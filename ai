local function UpdateIDE()
    local text = CodeBox.Text:gsub("\t", "    ")
    if CodeBox.Text ~= text then
        CodeBox.Text = text
    end
    
    local _, newlines = text:gsub("\n", "")
    local linesStr = ""
    for i = 1, newlines + 1 do
        linesStr = linesStr .. i .. "\n"
    end
    LineNums.Text = linesStr
    
    SyntaxDisp.Text = Lexer.Highlight(text)
    
    local bounds = TextService:GetTextSize(text, 13, Fonts.Code, Vector2.new(SyntaxDisp.AbsoluteSize.X, 999999))
    local canvasY = math.max(IDE_Cont.AbsoluteSize.Y, bounds.Y + 40)
    
    CodeScroll.CanvasSize = UDim2.new(0, 0, 0, canvasY)
    LineNumScroll.CanvasSize = UDim2.new(0, 0, 0, canvasY)
    
    SyntaxDisp.Size = UDim2.new(1, -20, 0, bounds.Y + 20)
    CodeBox.Size = UDim2.new(1, -20, 0, bounds.Y + 20)
    LineNums.Size = UDim2.new(1, -10, 0, bounds.Y + 20)
end

