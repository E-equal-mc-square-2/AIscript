        UI.Tween(MainFrame, {Size = UDim2.new(UserData.Scale, 0, UserData.Scale, 0)}, 0.4, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
    end
    task.wait(0.1)
    isToggling = false
end

