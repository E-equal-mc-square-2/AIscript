local UI = {}
function UI.Create(className, props) local inst = Instance.new(className) for k, v in pairs(props) do if type(k) == "string" then inst[k] = v else v.Parent = inst end end return inst end
function UI.Round(obj, radius) return UI.Create("UICorner", { CornerRadius = UDim.new(0, radius), Parent = obj }) end
function UI.Stroke(obj, color, thickness) return UI.Create("UIStroke", { Color = color, Thickness = thickness or 1, Parent = obj }) end
function UI.Gradient(obj, color1, color2, rotation) return UI.Create("UIGradient", { Color = ColorSequence.new{ColorSequenceKeypoint.new(0, color1), ColorSequenceKeypoint.new(1, color2)}, Rotation = rotation or 0, Parent = obj }) end

function UI.DropShadow(obj, size, transparency)
    return UI.Create("ImageLabel", { Name = "DropShadow", BackgroundTransparency = 1, Image = "rbxassetid://6015045625", ImageColor3 = Color3.fromRGB(0, 0, 0), ImageTransparency = transparency or 0.5, ScaleType = Enum.ScaleType.Slice, SliceCenter = Rect.new(9, 9, 21, 21), Size = UDim2.new(1, size*2, 1, size*2), Position = UDim2.new(0, -size, 0, -size), ZIndex = obj.ZIndex - 1, Parent = obj })
end

function UI.Tween(obj, properties, time, style, direction)
    local tween = TweenService:Create(obj, TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quart, direction or Enum.EasingDirection.Out), properties)
    tween:Play() return tween
end

function UI.MakeDraggableAndClickable(dragHandle, objectToMove, onClickCallback)
    local dragging = false
    local dragInput, dragStart, startPos, clickTime

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = objectToMove.Position
            clickTime = tick()
            if onClickCallback then UI.Tween(objectToMove, {Size = UDim2.new(0, 55, 0, 55)}, 0.1) end
        end
    end)

    dragHandle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                if onClickCallback then 
                    UI.Tween(objectToMove, {Size = UDim2.new(0, 65, 0, 65)}, 0.2, Enum.EasingStyle.Back)
                    local dist = (input.Position - dragStart).Magnitude
                    if input.Position.X == 0 and input.Position.Y == 0 then dist = 0 end 
                    
                    if dist < 15 and (tick() - clickTime) < 0.5 then
                        onClickCallback()
                    end
                end
            end
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            if input.Position.X == 0 and input.Position.Y == 0 then return end
            local delta = input.Position - dragStart
            objectToMove.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

