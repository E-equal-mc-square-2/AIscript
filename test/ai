local isProcessing = false

local function ExecuteCodeSecure(code)
    AddLog("Parsing AI generated bytecode...", CurrentTheme.Warning, false)
    local cleanCode = string.match(code, "```lua\n(.-)\n```") or string.match(code, "```(.-)```") or code
    
    -- Plugin-Safe loadstring bypass via ModuleScript compilation
    local tempModule = Instance.new("ModuleScript")
    tempModule.Name = "GeminiExecutionTemp"
    tempModule.Source = "return function()\n" .. cleanCode .. "\nend"
    
    local success, func = pcall(require, tempModule)
    if success and type(func) == "function" then
        AddLog("Compilation successful. Firing execution thread...", CurrentTheme.Success, false)
        local execSuccess, runtimeError = pcall(func)
        if execSuccess then 
            Notify("Execution Success", "Script successfully ran with 0 errors.", CurrentTheme.Success) 
            AddLog("Execution completed flawlessly.", CurrentTheme.Success, false)
        else 
            Notify("Runtime Error", "Script crashed during execution.", CurrentTheme.Error) 
            AddLog("Runtime Error: " .. tostring(runtimeError), CurrentTheme.Error, false) 
        end
    else 
        Notify("Compile Error", "AI generated invalid Lua syntax.", CurrentTheme.Error) 
        AddLog("Compile Error: " .. tostring(func), CurrentTheme.Error, false) 
    end
    
    tempModule:Destroy()
end

local function ProcessRequest(prompt)
    if isProcessing then return end
    if UserData.ApiKey == "" or #UserData.ApiKey < 10 then Notify("Missing API Key", "Please configure your key in settings.", CurrentTheme.Error) return end
    
    isProcessing = true StatusText.Text = "GEMINI IS THINKING..."
    UI.Tween(StatusText, {TextColor3 = CurrentTheme.AccentGlow}, 0.3)
    AddLog("Sending payload to Gemini " .. CONSTANTS.GEMINI_MODEL .. "...", CurrentTheme.TextPrimary, false)
    
    task.spawn(function()
        while isProcessing do
            UI.Tween(StatusText, {TextTransparency = 0.5}, 0.5) task.wait(0.5)
            UI.Tween(StatusText, {TextTransparency = 0}, 0.5) task.wait(0.5)
        end
        UI.Tween(StatusText, {TextTransparency = 0, TextColor3 = CurrentTheme.TextSecondary}, 0.3)
    end)
    
    local systemContext = "You are an elite, genius-level Roblox Studio Plugin assistant for KilometresSCP096. "
    if isCodeMode then systemContext = systemContext .. "You must output ONLY functional, highly optimized Roblox Lua script wrapped in ```lua ```. It will run in Studio Edit mode. Do NOT explain the code. You can create parts, format things, and automate builder tasks."
    else systemContext = systemContext .. "Respond to the user contextually about Roblox Studio development, scripting, and building. Be concise, hyper-intelligent, and formatted nicely." end
    
    local payload = HttpService:JSONEncode({ contents = {{ role = "user", parts = {{ text = prompt }} }}, systemInstruction = { parts = {{ text = systemContext }} }, generationConfig = { temperature = UserData.Temp } })
    
    task.spawn(function()
        local success, response = pcall(function() 
            return HttpService:RequestAsync({ 
                Url = CONSTANTS.API_URL .. UserData.ApiKey, 
                Method = "POST", 
                Headers = {["Content-Type"] = "application/json"}, 
                Body = payload 
            }) 
        end)
        
        isProcessing = false StatusText.Text = isCodeMode and "BUILDER MODE" or "CHAT MODE"
        
        if success and response.StatusCode == 200 then
            local data = HttpService:JSONDecode(response.Body)
            if data.candidates and data.candidates[1] then
                local aiResponse = data.candidates[1].content.parts[1].text
                if isCodeMode then 
                    AddLog("Received code payload from Gemini. Attempting execution...", CurrentTheme.Accent, false) 
                    AddLog(aiResponse, CurrentTheme.TextPrimary, true) 
                    ExecuteCodeSecure(aiResponse)
                else 
                    AddLog("Gemini: " .. aiResponse, CurrentTheme.TextPrimary, false) 
                end
            end
        else
            local err = response and response.StatusCode or "TIMEOUT/NET_ERROR"
            AddLog("API Handshake Failed (Error: " .. tostring(err) .. ")", CurrentTheme.Error, false) 
            Notify("API Error", "Failed to connect to Google Servers.", CurrentTheme.Error)
        end
    end)
end

ExecuteBtn.MouseButton1Click:Connect(function() local text = InputBox.Text if text ~= "" then InputBox.Text = "" AddLog("You: " .. text, CurrentTheme.TextSecondary, false) ProcessRequest(text) end end)

