local GUI_STATE = { OPEN = 1, CLOSED = 2 }
local CurrentState = GUI_STATE.OPEN
local isToggling = false

local function ToggleGUI(forceState)
    if isToggling then return end
    if forceState and forceState == CurrentState then return end
    isToggling = true

    if CurrentState == GUI_STATE.OPEN then
        CurrentState = GUI_STATE.CLOSED
        UI.Tween(SettingsModal, {Position = UDim2.new(0, 0, 1, 0)}, 0.2)
        UI.Tween(MainFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3)
        MainFrame.Visible = false
        
        FloatingBall.Size = UDim2.new(0, 0, 0, 0) 
        FloatingBall.Visible = true
        UI.Tween(FloatingBall, {Size = UDim2.new(0, 65, 0, 65)}, 0.4, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
    else
        CurrentState = GUI_STATE.OPEN
        UI.Tween(FloatingBall, {Size = UDim2.new(0, 0, 0, 0)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.2)
        FloatingBall.Visible = false
        
